DATABASE_URL="postgresql://optivision:optivision@localhost:5432/optivision_db"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"
PORT=5000
NODE_ENV=development
FRONTEND_URL="http://localhost:5173,https://your-app.vercel.app,https://*.vercel.app"

# Required for production seed (npm run db:seed)
SEED_ADMIN_EMAIL="admin@gmail.com"
SEED_ADMIN_PASSWORD="Admin@123"
SEED_ADMIN_NAME="System Administrator"
SEED_ADMIN_ROLE="SHOP_ADMIN"
SEED_ADMIN_PHONE="9999999999"

# Optional store bootstrap values
SEED_STORE_ID="store-main-01"
SEED_STORE_NAME="OptiVision"
SEED_STORE_ADDRESS=""
SEED_STORE_PHONE=""
SEED_STORE_EMAIL=""
SEED_STORE_GST_NUMBER=""
SEED_STORE_GST_ENABLED="false"
SEED_STORE_TAX_RATE="18"
SEED_INVOICE_PREFIX="INV"
